{
  "name": "webchat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch --import tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "node --import tsx server/index.ts"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.18"
  }
}
